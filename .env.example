# Host port Postgres is exposed on. Change this (and the port in the two URLs
# below) if 5432 is already taken by a local Postgres — e.g. set everything to 5433.
HOST_DB_PORT=5433

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/movies
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/movies_test
DATA_DIR=./data
API_PORT=3000
LOG_LEVEL=info
