{
  "name": "@mcd/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/server.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --outDir dist --clean",
    "start": "node dist/index.js",
    "db:generate": "npm run -w @mcd/db db:generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@mcd/db": "*",
    "close-with-grace": "^2.5.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-plugin": "5.0.1",
    "fastify-type-provider-zod": "6.1.0",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "tsup": "^8.5.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
